{
  "name": "ilgam",
  "private": true,
  "version": "0.1.0",
  "description": "ILGAM — Korean Senior Spot-Work Platform (monorepo)",
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:web": "turbo run dev --filter=@ilgam/admin-web",
    "dev:app": "turbo run dev --filter=@ilgam/worker-app",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "format": "prettier --write .",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.8.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
