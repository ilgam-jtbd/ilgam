# 일감 프로덕션 환경변수 템플릿
# 실값은 1Password > ILGAM Vault 에서 복사 (GitHub 리포에 절대 commit 금지)
# 2026-04-23 기준 ADR-006 참조

# ─── Supabase (ilgam-prod · ap-northeast-2) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://izeotpefhddrrwodgpry.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<from-1password>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<from-1password>
SUPABASE_PROJECT_REF=izeotpefhddrrwodgpry
# Session Pooler (IPv4 · 마이그레이션/ORM 용)
SUPABASE_DB_URL=postgresql://postgres.izeotpefhddrrwodgpry:<PW_URL_ENCODED>@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres
# Transaction Pooler (서버리스 · 짧은 쿼리용)
SUPABASE_DB_POOL=postgresql://postgres.izeotpefhddrrwodgpry:<PW_URL_ENCODED>@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# ─── PortOne ─────────────────────────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
PORTONE_WEBHOOK_SECRET=

# ─── KakaoTalk AlimTalk (Bizppurio) ──────────────────────
KAKAO_ALIMTALK_USER_ID=
KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_SENDER_KEY=

# ─── SMS 폴백 ────────────────────────────────────────────
SMS_PROVIDER=aligo
SMS_API_KEY=
SMS_SENDER_NUMBER=

# ─── Channel.io ──────────────────────────────────────────
CHANNEL_TALK_ACCESS_KEY=
CHANNEL_TALK_ACCESS_SECRET=
NEXT_PUBLIC_CHANNEL_PLUGIN_KEY=

# ─── Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN_WEB=
SENTRY_DSN_MOBILE=
SENTRY_DSN_EDGE=

# ─── PostHog ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=production
APP_REGION=ap-northeast-2
