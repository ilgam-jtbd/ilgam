# ─── Supabase (필수) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://izeotpefhddrrwodgpry.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<1Password > ILGAM Vault > Supabase anon key>

# ─── VWO A/B Testing (선택) ───────────────────────────────────
