# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:<pw>@<host>:5432/postgres
# 사이트 공식 도메인 (sitemap/robots/OG 에 사용). 미지정 시 https://ilgam.kr 기본
NEXT_PUBLIC_SITE_URL=https://ilgam.kr

# ─── Demo Mode (Vercel Preview 한정) ─────────────────────
# Supabase 자격증명 미수령 / 투자자·파트너 데모용 picture-perfect mock.
# admin-web RSC fetch 가 apps/admin-web/lib/demo.ts 의 fixture 로 단락된다.
# prod 에서 절대 활성화 금지 — 실 데이터 노출/RLS 우회 인상을 줌.
NEXT_PUBLIC_DEMO_MODE=0
# worker-app 동일 역할: prod 빌드 mock 차단. DEV 빌드는 자동 허용.
EXPO_PUBLIC_ALLOW_MOCK=false

# ─── PortOne ─────────────────────────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
PORTONE_WEBHOOK_SECRET=

# ─── KakaoTalk AlimTalk (via Bizppurio) ──────────────────
# notify-dispatch Edge Function 이 사용
BIZPPURIO_ACCOUNT_ID=
BIZPPURIO_API_KEY=
BIZPPURIO_SENDER_KEY=
BIZPPURIO_SENDER_NUMBER=

# ─── SMS fallback (Aligo) ────────────────────────────────
# AlimTalk R001/R002/T001 시 자동 폴백
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_NUMBER=
ALIGO_TESTMODE=0

# ─── Channel.io (CX) ─────────────────────────────────────
CHANNEL_TALK_ACCESS_KEY=
CHANNEL_TALK_ACCESS_SECRET=
NEXT_PUBLIC_CHANNEL_PLUGIN_KEY=

# ─── Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN_WEB=
SENTRY_DSN_MOBILE=
SENTRY_DSN_EDGE=

# ─── PostHog ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
APP_REGION=ap-northeast-2
