# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:<pw>@<host>:5432/postgres

# ─── PortOne ─────────────────────────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
PORTONE_WEBHOOK_SECRET=

# ─── KakaoTalk AlimTalk (via Bizppurio) ──────────────────
KAKAO_ALIMTALK_USER_ID=
KAKAO_ALIMTALK_API_KEY=
KAKAO_ALIMTALK_SENDER_KEY=

# ─── SMS fallback ────────────────────────────────────────
SMS_PROVIDER=aligo
SMS_API_KEY=
SMS_SENDER_NUMBER=

# ─── Channel.io (CX) ─────────────────────────────────────
CHANNEL_TALK_ACCESS_KEY=
CHANNEL_TALK_ACCESS_SECRET=
NEXT_PUBLIC_CHANNEL_PLUGIN_KEY=

# ─── Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN_WEB=
SENTRY_DSN_MOBILE=
SENTRY_DSN_EDGE=

# ─── PostHog ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
APP_REGION=ap-northeast-2
