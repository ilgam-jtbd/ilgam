# ─── Supabase ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:<pw>@<host>:5432/postgres

# ─── PortOne ─────────────────────────────────────────────
PORTONE_API_KEY=
PORTONE_API_SECRET=
PORTONE_CHANNEL_KEY=
PORTONE_WEBHOOK_SECRET=

# ─── KakaoTalk AlimTalk (via Bizppurio) ──────────────────
# notify-dispatch Edge Function 이 사용
BIZPPURIO_ACCOUNT_ID=
BIZPPURIO_API_KEY=
BIZPPURIO_SENDER_KEY=
BIZPPURIO_SENDER_NUMBER=

# ─── SMS fallback (Aligo) ────────────────────────────────
# AlimTalk R001/R002/T001 시 자동 폴백
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_NUMBER=
ALIGO_TESTMODE=0

# ─── Channel.io (CX) ─────────────────────────────────────
CHANNEL_TALK_ACCESS_KEY=
CHANNEL_TALK_ACCESS_SECRET=
NEXT_PUBLIC_CHANNEL_PLUGIN_KEY=

# ─── Claude API ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Sentry ──────────────────────────────────────────────
SENTRY_DSN_WEB=
SENTRY_DSN_MOBILE=
SENTRY_DSN_EDGE=

# ─── PostHog ─────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
APP_REGION=ap-northeast-2
